@model List<ClinicaJordan.Web.Models.Medico>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

@{
    ViewData["Title"] = "Pacientes";
}

@{
    ViewData["Title"] = "Medicos";
}

<h2>Lista de Médicos</h2>
<div class="d-flex flex-row align-items-center gap-4">
    <span>Crear un nuevo médico:</span>
    <a asp-action="Insertar" class="btn btn-sm btn-info">Insertar Médico</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>DNI</th>
                <th>Nombres</th>
                <th>Apellidos</th>
                <th>Correo</th>
                <th>Telefono</th>
                <th>Turno</th>
                <th>Especialidad</th>
                <th>FechaNacimiento</th>
                <th>FechaRegistro</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var medicos in Model)
            {
                <tr>
                    <td>@medicos.Dni</td>
                    <td>@medicos.Nombres</td>
                    <td>@medicos.Apellidos</td>
                    <td>@medicos.Correo</td>
                    <td>@medicos.Telefono</td>
                    <td>@medicos.Turno</td>
                    <td>@medicos.Especialidad</td>
                    <td>@medicos.FechaNacimiento</td>
                    <td>@medicos.FechaRegistro</td>
                    <td>@medicos.Estado</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Actualizar" asp-route-dni="@medicos.Dni" class="btn btn-warning">Editar</a>
                            <a asp-action="Desactivar" asp-route-dni="@medicos.Dni" class="btn btn-danger">Desactivar</a>
                        </div>
                    </td>
                </tr>    
            }
        </tbody>

    </table>
</div>

