@model ClinicaJordan.Web.Models.Paciente

@{
    ViewData["Title"] = "Actualizar Paciente";
}

<h2>Actualizar Paciente</h2>

<form asp-action="Actualizar" method="post">
    <div class="mb-3">
        <label asp-for="Dni" class="form-label">DNI</label>
        <input asp-for="Dni" class="form-control" disabled/>
        <input type="hidden" asp-for="Dni" />
    </div>
    <div class="mb-3">
        <label asp-for="Nombres" class="form-label">Nombres</label>
        <input asp-for="Nombres" class="form-control" disabled/>
        <input type="hidden" asp-for="Nombres" />
    </div>
    <div class="mb-3">
        <label asp-for="Apellidos" class="form-label">Apellidos</label>
        <input asp-for="Apellidos" class="form-control" disabled/>
        <input type="hidden" asp-for="Apellidos" />
    </div>
    <div class="mb-3">
        <label asp-for="Correo" class="form-label">Correo</label>
        <input asp-for="Correo" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Telefono" class="form-label">Telefono</label>
        <input asp-for="Telefono" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="FechaNacimiento" class="form-label">FechaNacimiento</label>
        <input asp-for="FechaNacimiento" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Peso" class="form-label">Peso (kg)</label>
        <input asp-for="Peso" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Altura" class="form-label">Altura (m)</label>
        <input asp-for="Altura" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Sexo" class="form-label">Sexo</label>
        <select asp-for="Sexo" class="form-select">
            <option value="M">Masculino</option>
            <option value="F">Femenino</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Estado" class="form-label">Estado</label>
        <select asp-for="Estado" class="form-select">
            <option value="A">Activo</option>
            <option value="I">Inactivo</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Actualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
