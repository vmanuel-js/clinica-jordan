@model ClinicaJordan.Web.Models.Especialidad

@{
    ViewData["Title"] = "Insertar Especialidad";
}

<form asp-action="Insertar" method="post">
    <div class="mb-3">
        <label asp-for="Nombre" class="form-label">Nombre</label>
        <input asp-for="Nombre" class="form-control" required/>
    </div>
    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label">Descripcion</label>
        <input asp-for="Descripcion" class="form-control" required/>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-danger">Cancelar</a>
</form>
